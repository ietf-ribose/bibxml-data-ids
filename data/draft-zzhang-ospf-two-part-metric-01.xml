    <title>OSPF Two-part Metric</title>
    <seriesInfo name="Internet-Draft" value="draft-zzhang-ospf-two-part-metric-01"/>
    <author initials="L." surname="Wang" fullname="Lili Wang"/>
    <author initials="D." surname="DuBois" fullname="Dave DuBois"/>
