    <title>Salt-Encryption of RADIUS Attributes</title>
    <seriesInfo name="Internet-Draft" value="draft-ietf-radius-saltencrypt-00"/>
    <author initials="D. C." surname="Fox" fullname="Daniel C. Fox"/>
