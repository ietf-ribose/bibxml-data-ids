  <front>
    <title>JWK Thumbprint URI</title>
    <seriesInfo name="Internet-Draft" value="draft-jones-oauth-jwk-thumbprint-uri-01"/>
    <author initials="M." surname="Jones" fullname="Michael Jones">
      <organization>Microsoft</organization>
