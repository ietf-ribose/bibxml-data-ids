    <title>EAP Authentication for SOCKS Version 5</title>
    <seriesInfo name="Internet-Draft" value="draft-ietf-aft-socks-eap-00"/>
    <author initials="G." surname="Zorn" fullname="Glen Zorn">
      <organization>Microsoft Corporation</organization>
