  <front>
    <title>The length of the prefix of an IPv6 link-local address ranges from 10 to 127</title>
    <seriesInfo name="Internet-Draft" value="draft-petrescu-6man-ll-prefix-len-14"/>
    <author initials="A." surname="Petrescu" fullname="Alexandre Petrescu">
      <organization>CEA, LIST</organization>
