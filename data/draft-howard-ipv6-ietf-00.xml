    <title>IETF: End Work on IPv4</title>
    <seriesInfo name="Internet-Draft" value="draft-howard-ipv6-ietf-00"/>
    <author initials="L." surname="Howard" fullname="Lee Howard">
      <organization>Charter</organization>
