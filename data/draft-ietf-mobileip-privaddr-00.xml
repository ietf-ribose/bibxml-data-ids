  <front>
    <title>Private Addresses in Mobile IP</title>
    <seriesInfo name="Internet-Draft" value="draft-ietf-mobileip-privaddr-00"/>
    <author initials="C. E." surname="Perkins" fullname="Charles E. Perkins">
      <organization>Pat R. Calhoun</organization>
