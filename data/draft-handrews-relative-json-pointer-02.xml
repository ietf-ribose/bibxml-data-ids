  <front>
    <title>Relative JSON Pointers</title>
    <seriesInfo name="Internet-Draft" value="draft-handrews-relative-json-pointer-02"/>
    <author initials="G." surname="Luff" fullname="Geraint Luff"/>
    <author initials="H." surname="Andrews" fullname="Henry Andrews"/>
