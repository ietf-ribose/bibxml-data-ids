    <title>Requirements for Scalable DNS-SD/mDNS Extensions</title>
    <seriesInfo name="Internet-Draft" value="draft-ietf-dnssd-requirements-04"/>
    <author initials="K." surname="Lynn" fullname="Kerry Lynn"/>
    <author initials="S." surname="Cheshire" fullname="Stuart Cheshire"/>
