    <title>BGP-signaled end-system IP/VPNs.</title>
    <seriesInfo name="Internet-Draft" value="draft-ietf-l3vpn-end-system-03"/>
    <author initials="P. R." surname="Marques" fullname="Pedro R. Marques"/>
