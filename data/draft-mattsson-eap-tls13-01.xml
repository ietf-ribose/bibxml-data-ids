    <title>Using EAP-TLS with TLS 1.3</title>
    <seriesInfo name="Internet-Draft" value="draft-mattsson-eap-tls13-01"/>
    <author initials="J. P." surname="Mattsson" fullname="John Preuß Mattsson">
      <organization>Ericsson</organization>
