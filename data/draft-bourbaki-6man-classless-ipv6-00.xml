  <front>
    <title>IPv6 is Classless</title>
    <seriesInfo name="Internet-Draft" value="draft-bourbaki-6man-classless-ipv6-00"/>
    <author initials="R." surname="Bush" fullname="Randy Bush"/>
    <author initials="B. E." surname="Carpenter" fullname="Brian E. Carpenter"/>
    <author initials="F." surname="Gont" fullname="Fernando Gont"/>
