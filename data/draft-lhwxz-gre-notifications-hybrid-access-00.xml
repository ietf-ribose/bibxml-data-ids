    <title>GRE Notifications for Hybrid Access</title>
    <seriesInfo name="Internet-Draft" value="draft-lhwxz-gre-notifications-hybrid-access-00"/>
    <author initials="N." surname="Leymann" fullname="Nicolai Leymann"/>
