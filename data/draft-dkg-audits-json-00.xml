    <title>Automated Discovery Of Audit Reports (audits.json)</title>
    <seriesInfo name="Internet-Draft" value="draft-dkg-audits-json-00"/>
    <author initials="D. K." surname="Gillmor" fullname="Daniel Kahn Gillmor">
