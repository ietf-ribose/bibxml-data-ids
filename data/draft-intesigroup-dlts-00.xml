  <front>
    <title>Distributed Ledger Time-Stamp</title>
    <seriesInfo name="Internet-Draft" value="draft-intesigroup-dlts-00"/>
    <author initials="E." surname="Cisbani" fullname="Emanuele Cisbani">
      <organization>Intesi Group</organization>
