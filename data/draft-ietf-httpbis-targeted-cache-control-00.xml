    <title>Targeted HTTP Cache Control</title>
    <seriesInfo name="Internet-Draft" value="draft-ietf-httpbis-targeted-cache-control-00"/>
    <author initials="S." surname="Ludin" fullname="Stephen Ludin">
      <organization>Akamai</organization>
