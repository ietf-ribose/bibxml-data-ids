  <front>
    <title>RPKI-Based Policy Without Route Refresh</title>
    <seriesInfo name="Internet-Draft" value="draft-ietf-sidrops-rov-no-rr-06"/>
    <author initials="R." surname="Bush" fullname="Randy Bush">
      <organization>IIJ Research Lab &amp; Arrcus, Inc.</organization>
