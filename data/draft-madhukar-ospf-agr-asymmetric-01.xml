  <front>
    <title>Asymmetric OSPF Hold Timer</title>
    <seriesInfo name="Internet-Draft" value="draft-madhukar-ospf-agr-asymmetric-01"/>
    <author initials="M." surname="Anand" fullname="Madhukar Anand">
