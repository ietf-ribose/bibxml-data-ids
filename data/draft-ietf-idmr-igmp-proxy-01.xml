  <front>
    <title>IGMP-based Multicast Forwarding ('IGMP Proxying')</title>
    <seriesInfo name="Internet-Draft" value="draft-ietf-idmr-igmp-proxy-01"/>
    <author initials="H." surname="He" fullname="Haixiang He">
      <organization>Nortel Networks</organization>
    </author>
    <author initials="B." surname="Haberman" fullname="Brian Haberman">
