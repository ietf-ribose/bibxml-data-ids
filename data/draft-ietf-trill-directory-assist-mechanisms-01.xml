    <title>TRILL: Edge Directory Assist Mechanisms</title>
    <seriesInfo name="Internet-Draft" value="draft-ietf-trill-directory-assist-mechanisms-01"/>
    <author initials="L." surname="Dunbar" fullname="Linda Dunbar"/>
    <author initials="D. E." surname="Eastlake" fullname="Donald E. Eastlake 3rd"/>
