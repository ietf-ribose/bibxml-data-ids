    <title>DNS Extension for ENUM Source-URI</title>
    <seriesInfo name="Internet-Draft" value="draft-kaplan-enum-source-uri-00"/>
    <author initials="H." surname="Kaplan" fullname="Hadriel Kaplan">
      <organization>Acme Packet</organization>
