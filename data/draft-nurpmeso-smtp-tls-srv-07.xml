    <title>Secure SMTP/TLS SRV Announcement</title>
    <seriesInfo name="Internet-Draft" value="draft-nurpmeso-smtp-tls-srv-07"/>
    <author initials="S." surname="Nurpmeso" fullname="Steffen Nurpmeso"/>
