  <front>
    <title>IETF: End Work on IPv4</title>
    <seriesInfo name="Internet-Draft" value="draft-ietf-sunset4-ipv6-ietf-00"/>
    <author initials="L." surname="Howard" fullname="Lee Howard">
      <organization>Retevia</organization>
