  <front>
    <title>Fragmentation support across RADIUS packets</title>
    <seriesInfo name="Internet-Draft" value="draft-perez-radext-radius-fragmentation-00"/>
    <author initials="A." surname="Pérez-Méndez" fullname="Alejandro Pérez-Méndez"/>
