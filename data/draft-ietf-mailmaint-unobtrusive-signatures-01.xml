    <title>Unobtrusive End-to-End Email Signatures</title>
    <seriesInfo name="Internet-Draft" value="draft-ietf-mailmaint-unobtrusive-signatures-01"/>
    <author initials="A." surname="Gallagher" fullname="Andrew Gallagher">
