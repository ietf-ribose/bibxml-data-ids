    <title>Hypertext Transfer Protocol (HTTP): Range Requests</title>
    <seriesInfo name="Internet-Draft" value="draft-fielding-httpbis-http-range-00"/>
    <author initials="R. T." surname="Fielding" fullname="Roy T. Fielding">
