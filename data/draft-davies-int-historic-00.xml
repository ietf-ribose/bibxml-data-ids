<reference anchor="I-D.davies-int-historic" target="https://datatracker.ietf.org/doc/html/draft-davies-int-historic-00">
  <front>
    <title>Deprecating infrastructure "int" domains</title>
    <seriesInfo name="Internet-Draft" value="draft-davies-int-historic-00"/>
    <author initials="K." surname="Davies" fullname="Kim Davies">
      <organization>Internet Assigned Numbers Authority</organization>
    </author>
    <author initials="A." surname="Baber" fullname="Amanda Baber">
      <organization>Internet Assigned Numbers Authority</organization>
    </author>
    <date day="25" month="March" year="2021"/>
    <abstract>
      <t>   The document marks as historic any "int" domain names that were
   designated for infrastructure purposes, and identifies them for
   removal from the "int" top-level domain.  Any implementation that
   involves these domains should be considered deprecated.

	 </t>
    </abstract>
  </front>
</reference>