  <front>
    <title>Device-Stock-UA HTTP Extension</title>
    <seriesInfo name="Internet-Draft" value="draft-brown-device-stock-ua-00"/>
    <author initials="T." surname="Brown" fullname="Tiffany Brown">
      <organization>Opera Software</organization>
    </author>
    <author initials="R." surname="Cremin" fullname="Ronan Cremin">
      <organization>Afilias Technologies Limited</organization>
    </author>
    <date day="12" month="November" year="2012"></date>
    <abstract>
      <t>   This document standardizes an HTTP extension header field that allows
   third-party HTTP clients and embeddable HTTP client components to
   include the user agent string of the HTTP-client that is bundled with
   the device operating system.

	 </t>
    </abstract>
  </front>
