    <title>PCP Third Party ID Option</title>
    <seriesInfo name="Internet-Draft" value="draft-ietf-pcp-third-party-id-option-00"/>
    <author initials="A." surname="Ripke" fullname="Andreas Ripke"/>
    <author initials="R." surname="Winter" fullname="Rolf Winter"/>
