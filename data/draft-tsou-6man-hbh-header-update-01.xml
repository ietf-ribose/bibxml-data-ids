  <front>
    <title>hop-by-hop extension header update</title>
    <seriesInfo name="Internet-Draft" value="draft-tsou-6man-hbh-header-update-01"/>
    <author initials="Z." surname="Chen" fullname="Zhonghua Chen">
      <organization>China Telecom</organization>
