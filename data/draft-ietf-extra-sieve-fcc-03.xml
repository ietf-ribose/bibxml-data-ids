  <front>
    <title>Sieve Extension: File Carbon Copy (Fcc)</title>
    <seriesInfo name="Internet-Draft" value="draft-ietf-extra-sieve-fcc-03"/>
    <author initials="K." surname="Murchison" fullname="Kenneth Murchison">
      <organization>FastMail US LLC</organization>
