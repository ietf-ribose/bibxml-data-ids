  <front>
    <title>The 'enum:' URI scheme</title>
    <seriesInfo name="Internet-Draft" value="draft-brandner-enum-uri-01"/>
    <author initials="R." surname="Brandner" fullname="Rudolf Brandner">
      <organization>Siemens</organization>
