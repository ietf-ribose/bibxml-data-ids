  <front>
    <title>VLAN Identifier option in DHCP</title>
    <seriesInfo name="Internet-Draft" value="draft-zhu-dhc-vlan-id-option-01"/>
    <author initials="C." surname="Zhu" fullname="Chunhui Zhu">
      <organization>ZTE Corporation</organization>
