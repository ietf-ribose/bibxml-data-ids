    <title>Multipath Extensions for QUIC (MP-QUIC)</title>
    <seriesInfo name="Internet-Draft" value="draft-deconinck-quic-multipath-04"/>
    <author initials="Q." surname="De Coninck" fullname="Quentin De Coninck">
