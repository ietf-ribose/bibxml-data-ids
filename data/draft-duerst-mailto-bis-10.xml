  <front>
    <title>The 'mailto' URI Scheme</title>
    <seriesInfo name="Internet-Draft" value="draft-duerst-mailto-bis-10"/>
    <author initials="J." surname="Zawinski" fullname="Jamie Zawinski">
      <organization>DNA Lounge</organization>
