    <title>Requirements for DNS-SD/mDNS Extensions</title>
    <seriesInfo name="Internet-Draft" value="draft-lynn-mdnsext-requirements-02"/>
    <author initials="K." surname="Lynn" fullname="Kerry Lynn">
