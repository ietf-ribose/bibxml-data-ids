  <front>
    <title>FMIPv6 extension for Multicast Handover</title>
    <seriesInfo name="Internet-Draft" value="draft-xia-mipshop-fmip-multicast-01"/>
    <author initials="F." surname="Xia" fullname="Frank Xia">
      <organization>Huawei USA</organization>
