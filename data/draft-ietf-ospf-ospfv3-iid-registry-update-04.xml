    <title>OSPFv3 Instance ID Registry Update</title>
    <seriesInfo name="Internet-Draft" value="draft-ietf-ospf-ospfv3-iid-registry-update-04"/>
    <author initials="A." surname="Retana" fullname="Alvaro Retana">
      <organization>Cisco Systems</organization>
