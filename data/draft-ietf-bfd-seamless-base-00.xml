    <title>Seamless Bidirectional Forwarding Detection (S-BFD)</title>
    <seriesInfo name="Internet-Draft" value="draft-ietf-bfd-seamless-base-00"/>
    <author initials="N." surname="Akiya" fullname="Nobo Akiya"/>
