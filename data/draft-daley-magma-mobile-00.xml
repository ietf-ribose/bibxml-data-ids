  <front>
    <title>Requirements for Mobile Multicast Clients</title>
    <seriesInfo name="Internet-Draft" value="draft-daley-magma-mobile-00"/>
    <author initials="G." surname="Daley" fullname="Greg Daley">
      <organization>Monash University CTIE</organization>
