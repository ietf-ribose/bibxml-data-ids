    <title>Happy Eyeballs Extension for ICE</title>
    <seriesInfo name="Internet-Draft" value="draft-reddy-mmusic-ice-happy-eyeballs-05"/>
    <author initials="T." surname="Reddy.K" fullname="Tirumaleswar Reddy.K"/>
