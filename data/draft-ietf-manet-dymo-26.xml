    <title>Dynamic MANET On-demand (AODVv2) Routing</title>
    <seriesInfo name="Internet-Draft" value="draft-ietf-manet-dymo-26"/>
    <author initials="C. E." surname="Perkins" fullname="Charles E. Perkins">
