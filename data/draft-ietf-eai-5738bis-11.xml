<reference anchor="I-D.ietf-eai-5738bis" target="https://datatracker.ietf.org/doc/html/draft-ietf-eai-5738bis-11">
  <front>
    <title>IMAP Support for UTF-8</title>
    <seriesInfo name="Internet-Draft" value="draft-ietf-eai-5738bis-11"/>
    <author initials="P." surname="Resnick" fullname="Pete Resnick"/>
    <author initials="C." surname="Newman" fullname="Chris Newman"/>
    <author initials="S." surname="Shen" fullname="Sean Shen"/>
    <date day="06" month="November" year="2012"/>
    <abstract>
      <t>   This specification extends the Internet Message Access Protocol
   version 4rev1 (IMAP4rev1) to support UTF-8 encoded international
   characters in user names, mail addresses and message headers.  This
   specification replaces RFC 5738.

	 </t>
    </abstract>
  </front>
</reference>