  <front>
    <title>Multicast VPN fast upstream failover</title>
    <seriesInfo name="Internet-Draft" value="draft-morin-bess-mvpn-fast-failover-00"/>
    <author initials="T." surname="Morin" fullname="Thomas Morin"/>
    <author initials="R." surname="Kebler" fullname="Robert Kebler"/>
