  <front>
    <title>POP3 Support for UTF-8</title>
    <seriesInfo name="Internet-Draft" value="draft-ietf-eai-rfc5721bis-07"/>
    <author initials="R." surname="Gellens" fullname="Randall Gellens"/>
    <author initials="C." surname="Newman" fullname="Chris Newman"/>
    <author initials="J." surname="Yao" fullname="Jiankang Yao"/>
    <author initials="K." surname="Fujiwara" fullname="Kazunori Fujiwara"/>
    <date day="31" month="July" year="2012"></date>
    <abstract>
      <t>   This specification extends the Post Office Protocol version 3 (POP3)
   to support UTF-8 encoded international string in user names,
   passwords, mail addresses, message headers, and protocol-level
   textual strings.

	 </t>
