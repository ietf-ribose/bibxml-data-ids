    <title>GSS-API Naming Extensions</title>
    <seriesInfo name="Internet-Draft" value="draft-ietf-kitten-gssapi-naming-exts-14"/>
    <author initials="N." surname="Williams" fullname="Nicol&#xE1;s Williams"/>
