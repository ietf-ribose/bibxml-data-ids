  <front>
    <title>AES Encryption with HMAC-SHA2 for Kerberos 5</title>
    <seriesInfo name="Internet-Draft" value="draft-ietf-kitten-aes-cbc-hmac-sha2-00"/>
    <author initials="M. J." surname="Jenkins" fullname="Michael J. Jenkins">
