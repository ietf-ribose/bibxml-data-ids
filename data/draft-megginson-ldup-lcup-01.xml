    <title>LDAP Client Update Protocol</title>
    <seriesInfo name="Internet-Draft" value="draft-megginson-ldup-lcup-01"/>
    <author initials="R." surname="Megginson" fullname="Rich Megginson"/>
    <author initials="M. C." surname="Smith" fullname="Mark C. Smith"/>
