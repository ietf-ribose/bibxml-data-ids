  <front>
    <title>Kerberos Set/Change Password: Version 2</title>
    <seriesInfo name="Internet-Draft" value="draft-ietf-cat-kerberos-set-passwd-06"/>
    <author initials="B." surname="Gossman" fullname="Bill Gossman">
