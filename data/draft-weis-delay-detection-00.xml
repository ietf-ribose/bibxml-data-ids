  <front>
    <title>IP Delivery Delay Detection Protocol</title>
    <seriesInfo name="Internet-Draft" value="draft-weis-delay-detection-00"/>
    <author initials="B." surname="Weis" fullname="Brian Weis"/>
    <author initials="U." surname="Mangla" fullname="Umesh Mangla"/>
