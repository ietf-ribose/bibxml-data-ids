    <title>The Time Zone Information Format (TZif)</title>
    <seriesInfo name="Internet-Draft" value="draft-murchison-rfc8536bis-05"/>
    <author initials="A. D." surname="Olson" fullname="Arthur David Olson"/>
    <author initials="P." surname="Eggert" fullname="Paul Eggert">
