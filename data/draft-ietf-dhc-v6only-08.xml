  <front>
    <title>IPv6-Only Preferred Option for DHCPv4</title>
    <seriesInfo name="Internet-Draft" value="draft-ietf-dhc-v6only-08"/>
    <author initials="L." surname="Colitti" fullname="Lorenzo Colitti">
