  <front>
    <title>Discrepancy detection between NMDA datastores</title>
    <seriesInfo name="Internet-Draft" value="draft-clemm-netconf-nmda-diff-01"/>
    <author initials="A." surname="Clemm" fullname="Alexander Clemm">
      <organization>Futurewei Technologies, Inc.</organization>
