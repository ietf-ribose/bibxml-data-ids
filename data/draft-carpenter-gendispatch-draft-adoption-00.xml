    <title>Process for Working Group Adoption of Drafts</title>
    <seriesInfo name="Internet-Draft" value="draft-carpenter-gendispatch-draft-adoption-00"/>
    <author initials="B. E." surname="Carpenter" fullname="Brian E. Carpenter">
