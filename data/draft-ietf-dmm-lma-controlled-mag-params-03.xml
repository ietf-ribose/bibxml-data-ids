    <title>LMA Controlled MAG Session Parameters</title>
    <seriesInfo name="Internet-Draft" value="draft-ietf-dmm-lma-controlled-mag-params-03"/>
    <author initials="D." surname="Patki" fullname="Dhananjay Patki"/>
