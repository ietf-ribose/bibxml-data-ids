    <title>Graceful Restart Mechanism for LDP</title>
    <seriesInfo name="Internet-Draft" value="draft-leelanivas-ldp-restart-01"/>
    <author initials="M. B." surname="Leelanivas" fullname="Manoj B. Leelanivas">
      <organization>Juniper Networks</organization>
