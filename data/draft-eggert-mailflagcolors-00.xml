  <front>
    <title>IMAP "$MailFlagBit" Keywords</title>
    <seriesInfo name="Internet-Draft" value="draft-eggert-mailflagcolors-00"/>
    <author initials="D." surname="Eggert" fullname="Daniel Eggert">
      <organization>Apple Inc</organization>
