  <front>
    <title>Usage of SPAKE with TLS 1.3</title>
    <seriesInfo name="Internet-Draft" value="draft-barnes-tls-pake-01"/>
    <author initials="R." surname="Barnes" fullname="Richard Barnes">
      <organization>Cisco</organization>
