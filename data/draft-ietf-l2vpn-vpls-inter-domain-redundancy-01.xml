  <front>
    <title>Redundancy provisioning for VPLS Inter-domain</title>
    <seriesInfo name="Internet-Draft" value="draft-ietf-l2vpn-vpls-inter-domain-redundancy-01"/>
    <author initials="Z." surname="Liu" fullname="Zhihua Liu"/>
